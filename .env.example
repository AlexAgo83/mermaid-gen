# Local environment documentation for Mermaid Generator.
# `VITE_*` variables are public frontend build-time configuration.
# `RENDER_*` variables are local Render service values for tooling and operations.
# Render is the production source of truth; mirror it locally in `.env.production` when needed.
VITE_APP_NAME=Mermaid Generator
VITE_APP_ENV=production
VITE_DEFAULT_DEBUG_OVERLAY=false

RENDER_API_KEY=
RENDER_SERVICE_ID=
RENDER_SERVICE_URL=

OPENAI_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=